{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "keys-vault",
  "compatibility_date": "2026-04-17",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
