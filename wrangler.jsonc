{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "keys-vault",
  "compatibility_date": "2026-04-17",
  "observability": {
    "enabled": true
  },
  "pages_build_output_dir": "dist",
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
